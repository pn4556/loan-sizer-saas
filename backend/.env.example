# Loan Sizer Automation - Environment Variables
# Copy this file to .env and fill in your values

# Anthropic API Key (optional - system works in demo mode without it)
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Default daily interest rate (used if not provided in request)
DEFAULT_RATE=8.50

# Email configuration
EMAIL_FROM=loans@yourcompany.com
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your-email@gmail.com
EMAIL_SMTP_PASS=your-app-password

# Paths
EXCEL_TEMPLATE_PATH=../demo-data/template.xlsx
OUTPUT_DIR=/tmp/sizer_outputs

# Optional: Database (SQLite used by default)
# DATABASE_URL=postgresql://user:pass@localhost/loans
